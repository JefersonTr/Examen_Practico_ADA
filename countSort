def countSort(arr):
n = len(arr)
mitad = n // 2
max_valor = 100
conteos = [[] for _ in range(max_valor)]

for i in range(n):
    num = int(arr[i][0])
    cadena = arr[i][1]

# Si el elemento pertenece a la primera mitad, se reemplaza por "-"
 if i < mitad:
    cadena = "-"

# Agregamos la cadena a la lista del número correspondiente
    conteos[num].append(cadena)
        
    resultado = []

for lista_cadenas in conteos:
    if lista_cadenas:
        resultado.extend(lista_cadenas)
            
    # Imprimir todas las cadenas separadas por un espacio en una sola línea
    print(*(resultado))

