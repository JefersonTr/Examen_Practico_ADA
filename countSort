    mi_lista = [
        ["1", "hola"],   # Índice 0 -> primera mitad -> "-"
        ["0", "mundo"],  # Índice 1 -> primera mitad -> "-"
        ["1", "python"], # Índice 2 -> primera mitad -> "-"
        ["0", "bueno"],  # Índice 3 -> segunda mitad -> conserva texto
        ["2", "adios"],  # Índice 4 -> segunda mitad -> conserva texto
        ["1", "clase"]   # Índice 5 -> segunda mitad -> conserva texto
    ]
    
    print("Salida del algoritmo: ")
    countSort(mi_lista)
